# Server
HOST=0.0.0.0
PORT=8080
REQUEST_BODY_LIMIT_BYTES=33554432
ENABLE_REQUEST_LOGGING=true

# Claude CLI
CLAUDE_BIN=claude
CLAUDE_DEFAULT_MODEL=sonnet
# Example:
# CLAUDE_MODEL_MAP_JSON={"claude-sonnet-4-20250514":"sonnet","claude-opus-4-20250514":"opus","claude-haiku-4-5":"haiku"}
CLAUDE_MODEL_MAP_JSON=
# Example:
# CLAUDE_EXTRA_ARGS_JSON=["--verbose"]
CLAUDE_EXTRA_ARGS_JSON=[]

# Proxy auth
# Optional bootstrap value. You can also set/update x-api-key later from /docs.
PROXY_API_KEY=
ALLOW_MISSING_API_KEY_HEADER=true
REQUIRE_ANTHROPIC_VERSION=false
DEFAULT_ANTHROPIC_VERSION=2023-06-01

# Web docs auth
# Required: set WEB_PASSWORD or WEB_PASSWORD_HASH before starting the server.
WEB_PASSWORD_HASH=
WEB_PASSWORD=
WEB_SESSION_TTL_HOURS=12
WEB_LOGIN_MAX_ATTEMPTS=5
WEB_LOGIN_WINDOW_MINUTES=15
