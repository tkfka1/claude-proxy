# Server
HOST=0.0.0.0
PORT=8080
REQUEST_BODY_LIMIT_BYTES=33554432
ENABLE_REQUEST_LOGGING=true
MAX_CONCURRENT_MESSAGE_REQUESTS=4
MAX_QUEUED_MESSAGE_REQUESTS=16
RECENT_LOG_LIMIT=200

# Claude CLI
CLAUDE_BIN=claude
CLAUDE_DEFAULT_MODEL=sonnet
# Example:
# CLAUDE_MODEL_MAP_JSON={"claude-sonnet-4-20250514":"sonnet","claude-opus-4-20250514":"opus","claude-haiku-4-5":"haiku"}
CLAUDE_MODEL_MAP_JSON=
# Example:
# CLAUDE_EXTRA_ARGS_JSON=["--verbose"]
CLAUDE_EXTRA_ARGS_JSON=[]

# Proxy auth
# Optional first-run bootstrap value. After /docs saves a key, the persisted state keeps winning on restart.
PROXY_API_KEY=
# Optional explicit state file for persisted x-api-key overrides.
# Default: $XDG_STATE_HOME/claude-anthropic-proxy/runtime-state.json
# or $HOME/.local/state/claude-anthropic-proxy/runtime-state.json
PROXY_STATE_FILE=
# Optional explicit file for persisted recent logs shown in /docs and /logs/recent.
# Default: $XDG_STATE_HOME/claude-anthropic-proxy/recent-log.json
# or $HOME/.local/state/claude-anthropic-proxy/recent-log.json
RECENT_LOG_FILE=
# Optional Redis backend. When REDIS_URL is set, x-api-key state and recent logs move to Redis instead of local files.
REDIS_URL=
REDIS_KEY_PREFIX=claude-anthropic-proxy
ALLOW_MISSING_API_KEY_HEADER=true
REQUIRE_ANTHROPIC_VERSION=false
DEFAULT_ANTHROPIC_VERSION=2023-06-01

# Web docs auth
# Required: set WEB_PASSWORD or WEB_PASSWORD_HASH before starting the server.
WEB_PASSWORD_HASH=
WEB_PASSWORD=
WEB_SESSION_TTL_HOURS=12
WEB_LOGIN_MAX_ATTEMPTS=5
WEB_LOGIN_WINDOW_MINUTES=15
